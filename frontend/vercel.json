{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_YOUR_RAILWAY_URL/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://REPLACE_WITH_YOUR_RAILWAY_URL/health"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
